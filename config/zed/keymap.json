[
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
    },
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "tab": "editor::AcceptEditPrediction",
      "enter": "editor::ConfirmCompletion",
    },
  },
]
